# Copy to .env and fill. NEVER commit .env.
# Get keys here:
#   EIA_API_KEY  -> https://www.eia.gov/opendata/register.php  (free, instant)
#   NOAA_USER_AGENT -> any "appname contact@email" string (required by api.weather.gov)
#   ERCOT MIS     -> developer token required; connector intentionally not wired yet
#   CAISO OASIS   -> public, no key; rate-limit ~1 rps

EIA_API_KEY=
NOAA_USER_AGENT=collide-energy-pipeline sdonthi4@asu.edu

# Where to write the data lake. Override for Colab / GCS.
DATA_ROOT=./data

# Logging
LOG_LEVEL=INFO
