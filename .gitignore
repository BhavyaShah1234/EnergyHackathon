# Secrets — NEVER commit
.env
.env.*
!.env.example
*.key
*.pem
credentials.json

# Data lake — large, reproducible; keep dir structure via .gitkeep only.
# Must glob contents (trailing /*), not the dir itself, or negation can't reach in.
data/raw/*
data/bronze/*
data/silver/*
data/quarantine/*
data/_meta/*
data/_samples/*
!data/_samples/*.csv
!data/_samples/*.json
!data/raw/.gitkeep
!data/bronze/.gitkeep
!data/silver/.gitkeep
!data/quarantine/.gitkeep
!data/_meta/.gitkeep

# Logs
logs/*.log
logs/*.jsonl

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp
